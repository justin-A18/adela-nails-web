---
import { RESERVATION_URL } from "../../const/navigation";
import { SERVICES, SERVICE_GUIDE } from "../../const/services";
import GuidanceIcon from "../icons/GuidanceIcon.astro";
import ServiceIcon from "../icons/ServiceIcon.astro";
---

<section
	id="servicios"
	class="overflow-hidden bg-[var(--color-bg)] px-6 py-16 lg:px-8 lg:py-24"
>
	<div class="mx-auto max-w-7xl">
		<div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
			<div class="scroll-reveal">
				<p
					class="text-xs font-bold uppercase tracking-[0.26em] text-[var(--color-primary-soft)]"
				>
					Servicios
				</p>
				<h2
					class="mt-3 max-w-3xl font-serif text-4xl leading-tight text-[var(--color-primary-dark)] sm:text-5xl"
				>
					El servicio correcto según lo que tus uñas necesitan
				</h2>
				<p
					class="mt-5 max-w-2xl text-sm leading-7 text-[var(--color-text-muted)]"
				>
					No todas las técnicas resuelven lo mismo. Elegimos entre extensión,
					refuerzo, color o estructura según tu uña natural, tu rutina y el
					acabado que buscas.
				</p>
			</div>

			<div
				class="scroll-reveal rounded-2xl border border-[var(--color-border)] bg-white/78 p-4 shadow-[var(--shadow-soft)] sm:p-5"
				style="--scroll-delay: 90ms"
			>
				<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<p class="text-xs font-bold uppercase tracking-[0.22em] text-[var(--color-primary-soft)]">
							Asesoría rápida
						</p>
						<p class="mt-2 text-base font-bold text-[var(--color-text)]">
							¿Llegas sin saber qué pedir?
						</p>
					</div>
					<a
						href={RESERVATION_URL}
						class="inline-flex min-h-11 shrink-0 items-center justify-center gap-2 rounded-md bg-[var(--color-primary)] px-5 text-sm font-bold text-white transition hover:bg-[var(--color-primary-dark)]"
					>
						<GuidanceIcon class="size-4" />
						Te orientamos
					</a>
				</div>
			</div>
		</div>

		<div
			class="mt-10 grid overflow-hidden rounded-2xl border border-[var(--color-border)] bg-white shadow-[var(--shadow-soft)] md:grid-cols-4"
		>
			{
				SERVICE_GUIDE.map((item, index) => (
					<div
						class:list={[
							"scroll-reveal relative p-5 md:border-r md:border-[var(--color-border)]",
							index === SERVICE_GUIDE.length - 1 ? "md:border-r-0" : "",
						]}
						style={`--scroll-delay: ${index * 70}ms`}
					>
						<div class="flex items-center gap-3">
							<span class="grid size-8 shrink-0 place-items-center rounded-full bg-[var(--color-bg-soft)] text-xs font-bold text-[var(--color-primary)]">
								{index + 1}
							</span>
							<p class="text-sm font-bold text-[var(--color-text)]">
								{item.intent}
							</p>
						</div>
						<p class="mt-4 font-serif text-2xl text-[var(--color-primary-dark)]">
							{item.service}
						</p>
						<p class="mt-2 text-sm leading-6 text-[var(--color-text-muted)]">
							{item.detail}
						</p>
					</div>
				))
			}
		</div>

		<div class="mt-7 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
			{
				SERVICES.map((service, index) => (
					<article
						class:list={[
							"scroll-reveal group flex min-h-[360px] flex-col rounded-2xl border bg-white p-5 shadow-[var(--shadow-soft)] transition duration-300 hover:-translate-y-1 hover:border-[var(--color-primary-soft)] hover:shadow-[var(--shadow-card)]",
							service.featured
								? "border-[var(--color-primary-soft)]"
								: "border-[var(--color-border)]",
						]}
						style={`--scroll-delay: ${index * 70}ms`}
					>
						<div class="flex items-start justify-between gap-4">
							<div
								class:list={[
									"grid size-12 shrink-0 place-items-center rounded-full",
									service.featured
										? "bg-[var(--color-primary)] text-white"
										: "bg-[var(--color-bg-soft)] text-[var(--color-primary-soft)]",
								]}
							>
								<ServiceIcon name={service.icon} class="size-7" />
							</div>
							<span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-xs font-bold text-[var(--color-primary)]">
								{service.bestFor}
							</span>
						</div>

						<h3 class="mt-6 text-xl font-bold leading-snug text-[var(--color-text)]">
							{service.title}
						</h3>

						<p class="mt-3 text-sm leading-7 text-[var(--color-text-muted)]">
							{service.description}
						</p>

						<div class="mt-auto pt-6">
							<div class="grid grid-cols-2 gap-2 text-xs">
								<div class="rounded-xl bg-[var(--color-bg-soft)] px-3 py-3">
									<p class="text-[var(--color-text-light)]">Acabado</p>
									<p class="mt-1 font-bold text-[var(--color-text)]">
										{service.finish}
									</p>
								</div>
								<div class="rounded-xl bg-[var(--color-bg-soft)] px-3 py-3">
									<p class="text-[var(--color-text-light)]">Refuerzo</p>
									<p class="mt-1 font-bold text-[var(--color-text)]">
										{service.strength}
									</p>
								</div>
							</div>

							<a
								href={RESERVATION_URL}
								class="mt-5 inline-flex w-full min-h-11 items-center justify-center gap-2 rounded-md border border-[var(--color-border-strong)] text-sm font-bold text-[var(--color-primary)] transition hover:border-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-white"
							>
								Consultar
								<span aria-hidden="true">→</span>
							</a>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
