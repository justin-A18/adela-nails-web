---
import { SERVICES } from "../../const/services";
import ServiceIcon from "../icons/ServiceIcon.astro";

const featuredService = SERVICES.find((service) => service.featured) ?? SERVICES[0];
const regularServices = SERVICES.filter((service) => service !== featuredService);
---

<section
	id="servicios"
	class="bg-[var(--color-bg)] px-6 py-16 lg:px-8 lg:py-24"
>
	<div class="mx-auto max-w-7xl">
		<div class="mx-auto max-w-4xl text-center">
			<p
				class="text-xs font-bold uppercase tracking-[0.26em] text-[var(--color-primary-soft)]"
			>
				Servicios
			</p>
			<h2
				class="mt-3 font-serif text-4xl leading-tight text-[var(--color-primary-dark)] sm:text-5xl"
			>
				Servicios para uñas con estructura, brillo y duración
			</h2>
			<div class="mx-auto mt-4 h-px w-16 bg-[var(--color-accent)]"></div>
			<p
				class="mx-auto mt-5 max-w-2xl text-sm leading-7 text-[var(--color-text-muted)]"
			>
				Desde bases flexibles hasta extensiones con arquitectura, cada servicio
				se trabaja con técnica, higiene y una terminación pulida.
			</p>
		</div>

		<div class="mt-12 grid gap-5 lg:grid-cols-[1.08fr_1.42fr]">
			<article
				class="relative isolate overflow-hidden rounded-2xl bg-[var(--color-primary)] p-7 text-white shadow-[var(--shadow-card)] sm:p-8"
			>
				<div
					class="absolute -right-16 -top-16 size-48 rounded-full border border-white/10"
				>
				</div>
				<div
					class="absolute -bottom-24 right-8 size-56 rounded-full bg-white/5"
				>
				</div>

				<div
					class="grid size-16 place-items-center rounded-full bg-white/10 text-[var(--color-accent-light)]"
				>
					<ServiceIcon name={featuredService.icon} class="size-10" />
				</div>

				<p class="mt-10 text-xs font-bold uppercase tracking-[0.26em] text-white/60">
					Servicio destacado
				</p>
				<h3 class="mt-4 font-serif text-4xl leading-tight text-white">
					{featuredService.title}
				</h3>
				<p class="mt-5 max-w-md text-base leading-8 text-white/78">
					{featuredService.description}
				</p>

				<a
					href="https://wa.me/"
					class="mt-8 inline-flex min-h-12 items-center justify-center rounded-md bg-white px-6 text-sm font-bold text-[var(--color-primary)] transition hover:bg-[var(--color-bg-soft)]"
				>
					Consultar disponibilidad
				</a>
			</article>

			<div class="grid gap-4 sm:grid-cols-2">
				{
					regularServices.map((service, index) => (
					<article
						class="group rounded-2xl border border-[var(--color-border)] bg-white/72 p-6 shadow-[var(--shadow-soft)] transition duration-300 hover:-translate-y-1 hover:border-[var(--color-border-strong)] hover:bg-white"
					>
						<div class="flex items-start justify-between gap-5">
							<div class="grid size-12 shrink-0 place-items-center rounded-full bg-[var(--color-bg-soft)] text-[var(--color-primary-soft)]">
								<ServiceIcon name={service.icon} class="size-7" />
							</div>
							<span class="font-serif text-4xl leading-none text-[var(--color-accent-light)]">
								{String(index + 1).padStart(2, "0")}
							</span>
						</div>

						<h3 class="mt-7 text-xl font-bold leading-snug text-[var(--color-text)]">
							{service.title}
						</h3>

						<p class="mt-4 text-sm leading-7 text-[var(--color-text-muted)]">
							{service.description}
						</p>

						<a
							href="https://wa.me/"
							class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-[var(--color-primary)]"
						>
							Consultar disponibilidad
							<span aria-hidden="true">→</span>
						</a>
					</article>
				))
				}
			</div>
		</div>
	</div>
</section>
