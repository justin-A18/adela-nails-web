---
import { Picture } from "astro:assets";
import heroImage from "../../assets/hero-img.png";
import HeroSparklesIcon from "../icons/HeroSparklesIcon.astro";
import WhatsAppIcon from "../icons/WhatsAppIcon.astro";
---

<section
	class="hero-section relative isolate grid min-h-[calc(100dvh-112px)] grid-cols-1 items-center gap-10 overflow-hidden px-6 pb-14 pt-6 lg:grid-cols-[0.95fr_1.05fr] lg:px-8"
>
	<HeroSparklesIcon
		class="hero-sparkles pointer-events-none absolute right-8 top-24 h-20 w-20 text-[var(--color-accent)] opacity-45 sm:right-14 lg:right-4"
	/>

	<div
		class="hero-copy lg:max-w-2xl flex flex-col sm:items-center w-full sm:text-center lg:text-start lg:items-start"
	>
		<p
			class="hero-reveal mb-5 text-xs font-bold uppercase tracking-[0.26em] text-[var(--color-primary-soft)]"
			style="--hero-delay: 80ms"
		>
			Diseño de uñas con técnica
		</p>

		<h1
			class="hero-reveal font-serif text-5xl leading-[1.08] text-[var(--color-primary-dark)] sm:text-6xl lg:text-7xl"
			style="--hero-delay: 170ms"
		>
			Uñas elegantes, diseñadas para expresar tu
			<em class="font-serif italic text-[var(--color-primary)]">estilo</em>
		</h1>

		<p
			class="hero-reveal mt-7 max-w-xl text-base leading-8 text-[var(--color-text-muted)] sm:text-lg"
			style="--hero-delay: 280ms"
		>
			Servicios especializados en Soft Gel, Polygel, Semipermanente, Rubber y
			Gel de construcción, pensados para cuidar cada detalle con técnica,
			higiene y un acabado limpio y duradero.
		</p>

		<div
			class="hero-reveal mt-8 flex flex-col gap-4 sm:flex-row"
			style="--hero-delay: 390ms"
		>
			<a
				href="https://wa.me/"
				class="inline-flex min-h-14 items-center justify-center gap-3 rounded-md bg-[var(--color-primary)] px-8 text-sm font-bold text-white shadow-[var(--shadow-card)] transition hover:bg-[var(--color-hover)]"
			>
				<WhatsAppIcon class="size-5" />
				Reservar por WhatsApp
			</a>

			<a
				href="/#servicios"
				class="inline-flex min-h-14 items-center justify-center rounded-md border border-[var(--color-primary-soft)] bg-white/45 px-8 text-sm font-bold text-[var(--color-primary)] transition hover:bg-white/75"
			>
				Ver servicios
			</a>
		</div>

		<ul
			class="hero-reveal mt-8 flex flex-col gap-3 text-xs font-semibold text-[var(--color-text-light)] sm:flex-row sm:flex-wrap sm:items-center sm:gap-6"
			style="--hero-delay: 500ms"
		>
			<li class="flex items-center gap-2">
				<span class="size-2 rounded-full bg-[var(--color-accent)]"></span>
				Atención personalizada
			</li>
			<li class="flex items-center gap-2">
				<span class="size-2 rounded-full bg-[var(--color-accent)]"></span>
				Productos profesionales
			</li>
			<li class="flex items-center gap-2">
				<span class="size-2 rounded-full bg-[var(--color-accent)]"></span>
				Acabados de larga duración
			</li>
		</ul>
	</div>

	<div
		class="hero-visual relative flex min-h-[320px] w-full items-end justify-center sm:min-h-[430px] lg:min-h-[560px]"
	>
		<Picture
			src={heroImage}
			alt="Manicure elegante con uñas color vino"
			formats={["avif", "webp"]}
			fallbackFormat="webp"
			widths={[280, 320, 420, 560, 720]}
			sizes="(min-width: 1024px) 560px, (min-width: 640px) 420px, 300px"
			loading="eager"
			decoding="async"
			fetchpriority="high"
			class="hero-image relative z-10 mx-auto max-h-[320px] w-full max-w-[300px] object-contain drop-shadow-xl sm:max-h-[440px] sm:max-w-[420px] lg:max-h-[640px] lg:max-w-[560px] lg:drop-shadow-2xl"
		/>
	</div>
</section>
