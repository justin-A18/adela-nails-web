---
import { RESERVATION_URL } from "../../const/navigation";
import CalendarIcon from "../icons/CalendarIcon.astro";
import BrandLogo from "./BrandLogo.astro";
import DesktopNav from "./DesktopNav.astro";
import MobileMenu from "./MobileMenu.astro";
---

<header class="relative z-50 w-full">
	<nav
		class="mx-auto flex w-full max-w-7xl items-center justify-between gap-6 px-6 py-6 lg:px-8"
		aria-label="Navegación principal"
	>
		<BrandLogo />
		<DesktopNav />

		<a
			href={RESERVATION_URL}
			class="hidden min-h-11 items-center justify-center gap-2 rounded-md bg-[var(--color-primary)] px-5 text-sm font-bold text-white shadow-[var(--shadow-soft)] transition hover:bg-[var(--color-hover)] lg:inline-flex"
		>
			<CalendarIcon class="size-4" />
			Reserva tu cita
		</a>

		<MobileMenu />
	</nav>
</header>
