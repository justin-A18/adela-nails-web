---
type IconName = "soft-gel" | "polygel" | "semipermanent" | "rubber" | "builder-gel";

const { name, class: className = "" } = Astro.props as {
	name: IconName;
	class?: string;
};
---

<svg
	aria-hidden="true"
	class={className}
	viewBox="0 0 64 64"
	fill="none"
	stroke="currentColor"
	stroke-width="2"
	stroke-linecap="round"
	stroke-linejoin="round"
>
	{
		name === "soft-gel" && (
			<>
				<path d="M24 51c-5-8-7-18-5-29 1-6 5-10 10-10 4 0 7 3 8 8 2 11 0 22-5 31" />
				<path d="M40 48c4-7 6-16 4-25-1-5-4-8-8-9" />
				<path d="M22 37c5 3 10 3 15 0" />
				<path d="M27 13c-2 7-2 16 0 25" />
			</>
		)
	}
	{
		name === "polygel" && (
			<>
				<path d="M20 46h24" />
				<path d="M24 46 20 25c-1-5 3-10 8-10h8c5 0 9 5 8 10l-4 21" />
				<path d="M27 23h10" />
				<path d="M29 31h6" />
				<path d="M18 52h28" />
			</>
		)
	}
	{
		name === "semipermanent" && (
			<>
				<path d="M26 7h12v16H26z" />
				<path d="M22 23h20v30H22z" />
				<path d="M27 31h10" />
				<path d="M28 40c0 4 8 4 8 0 0-5-8-5-8-10" />
				<path d="M29 14h6" />
			</>
		)
	}
	{
		name === "rubber" && (
			<>
				<path d="M18 36c4-13 10-20 18-20 6 0 10 5 10 12 0 13-9 22-22 22-7 0-11-4-9-10 1-3 4-4 8-4 8 0 14-4 17-11" />
				<path d="M26 43c5 1 10-1 14-5" />
			</>
		)
	}
	{
		name === "builder-gel" && (
			<>
				<path d="M20 50c-3-9-2-21 3-31 2-4 5-7 9-7s7 3 9 7c5 10 6 22 3 31" />
				<path d="M24 38c5 3 11 3 16 0" />
				<path d="M32 13v37" />
				<path d="M23 26h18" />
			</>
		)
	}
</svg>
